<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000">

    <LinearLayout
        android:id="@+id/cutsceneBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:background="#E0000000"
        android:clipToPadding="false"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:padding="24dp"
        android:gravity="center_vertical"
        android:maxWidth="900dp">

        <ImageView
            android:id="@+id/cutsceneImage"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_weight="1"
            android:scaleType="centerInside"
            android:src="@drawable/ic_launcher_foreground"
            android:layout_marginEnd="18dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:orientation="vertical"
            android:gravity="center_vertical|start">

            <TextView
                android:id="@+id/cutsceneTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:text="@string/dialog_cutscene_title_placeholder"
                android:textColor="#FFD700"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true"
                android:layout_marginBottom="8dp">
                <TextView
                    android:id="@+id/cutsceneDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text="@string/dialog_cutscene_description_placeholder"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:padding="2dp"/>
            </ScrollView>
        </LinearLayout>

        <Button
            android:id="@+id/cutsceneOkButton"
            android:layout_width="wrap_content"
            android:layout_height="180dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="18dp"
            android:backgroundTint="#FFD700"
            android:text="@string/dialog_ok"
            android:textColor="#222" />
    </LinearLayout>

</RelativeLayout> 